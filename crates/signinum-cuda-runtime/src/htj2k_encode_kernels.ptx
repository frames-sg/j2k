    .param .u64 vlc_table0,
    .param .u64 vlc_table1,
    .param .u64 uvlc_table,
    .param .u64 statuses,
    .param .u64 job_count
)
{
    ret;
}

.visible .entry signinum_htj2k_packetize_cleanup(
    .param .u64 payload,
    .param .u64 payload_len,
    .param .u64 packets,
    .param .u64 subbands,
    .param .u64 blocks,
    .param .u64 tag_states,
    .param .u64 tag_nodes,
    .param .u64 tag_state_count,
