{
  "threshold": 3.34,
  "minLines": 20,
  "minTokens": 50,
  "maxLines": 20000,
  "maxSize": "2mb",
  "mode": "mild",
  "format": ["rust"],
  "reporters": ["console", "json"],
  "output": "target/clone-audit/report",
  "gitignore": false,
  "ignore": [
    "**/benches/**",
    "**/examples/**",
    "**/fuzz/**",
    "**/generated/**",
    "**/tests/**",
    "**/*_tests.rs",
    "**/tests.rs",
    "**/test_*.rs",
    "**/*_test.rs",
    "**/test_helpers.rs",
    "**/test_support.rs",
    "**/build.rs",
    "**/j2k-test-support/**",
    "**/j2k-transcode-test-support/**"
  ]
}
